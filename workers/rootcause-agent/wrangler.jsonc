{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rootcause-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOTCAUSE_AGENT",
        "class_name": "RootCauseAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RootCauseAgent"]
    }
  ]
}

