{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prevention-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "PREVENTION_AGENT",
        "class_name": "PreventionAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PreventionAgent"]
    }
  ]
}

